{
  "name": "bolao-copa-petfunny",
  "version": "0.2.26",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm --prefix backend start",
    "dev": "npm --prefix backend run dev",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:seed": "npm --prefix backend run db:seed",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "postinstall": "npm install --prefix backend",
    "build": "npm install --prefix backend && npm --prefix backend run db:migrate",
    "render:build": "npm install --prefix backend && npm --prefix backend run db:migrate",
    "render:start": "npm --prefix backend start"
  },
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  }
}
