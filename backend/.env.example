# Pode copiar este arquivo para backend/.env se preferir.
# O projeto também aceita .env na raiz.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bolao_copa_petfunny
DATABASE_SSL=auto
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3000
APP_NAME=Bolão da Copa PetFunny
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@petfunny.com.br
ADMIN_PASSWORD=petfunny123
PREDICTION_CLOSE_MINUTES=10
DEFAULT_PRIZE=Banho grátis PetFunny
MERCADO_PAGO_ACCESS_TOKEN=
# auto: usa auto_return apenas quando PUBLIC_BASE_URL é HTTPS público.
# false: desativa auto_return, ideal para localhost.
# true: força auto_return quando houver back_urls válidas.
MERCADO_PAGO_AUTO_RETURN=auto
# URL pública HTTPS para webhook do Mercado Pago. Em localhost deixe vazio.
# No Render pode deixar vazio se PUBLIC_BASE_URL=https://seu-app.onrender.com estiver correto.
MERCADO_PAGO_NOTIFICATION_URL=
PAYMENT_DEMO_AUTOPAY=false
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_ALLOW_TEST_PIX=false
MERCADO_PAGO_PIX_EXPIRATION_MINUTES=15
RESET_TOKEN_EXPIRES_MINUTES=60
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bolão da Copa PetFunny <no-reply@petfunny.com.br>"
